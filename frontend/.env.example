# URL base do backend Spring Boot
VITE_API_URL=http://localhost:8080

# OAuth2 Client (deve estar registrado no AuthorizationServerConfiguration.java)
VITE_CLIENT_ID=vulpes-fiscal-web
VITE_CLIENT_SECRET=

# URI de redirecionamento após login OAuth2 (Authorization Code flow)
VITE_REDIRECT_URI=http://localhost:5173/callback
